# ── Google OAuth (required) ──────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
ALLOWED_HOSTED_DOMAIN=brac.net

# ── Session (required) ───────────────────────────────────────────────────────
SESSION_SECRET=a-long-random-string-min-32-chars

# ── AWS (required in production) ─────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_BEDROCK_KB_ID=your-bedrock-knowledge-base-id

# ── AWS credentials (local dev only — use IAM role on Amplify) ───────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── AWS optional ─────────────────────────────────────────────────────────────
# Full model ARN — defaults to Claude 3 Sonnet in AWS_REGION
# AWS_BEDROCK_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-3-sonnet-20240229-v1:0

# DynamoDB table prefix — tables will be e.g. BracHRConversations
# DYNAMO_TABLE_PREFIX=BracHR

# ── Limits / cache (optional) ────────────────────────────────────────────────
# RATE_LIMIT_PER_HOUR=30
# SESSION_HOURS=8
# ANSWER_CACHE_TTL_SECONDS=3600

# ── Local dev mock mode (never set in production) ────────────────────────────
# MOCK_MODE=true
